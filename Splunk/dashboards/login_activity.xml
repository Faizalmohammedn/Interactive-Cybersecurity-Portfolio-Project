<form version="1.1" theme="dark">
  <label>SOC Lab - Login Activity</label>
  <description>Failed and successful logons for the training lab</description>
  <fieldset submitButton="false">
    <input type="time" token="time">
      <default>
        <earliest>-24h@h</earliest>
        <latest>now</latest>
      </default>
    </input>
  </fieldset>
  <row>
    <panel>
      <title>Failed Windows Logons (4625)</title>
      <chart>
        <search>
          <query>index=windows EventCode=4625 | timechart span=10m count as failed_logons</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
        </search>
        <option name="charting.chart">column</option>
      </chart>
    </panel>
    <panel>
      <title>Successful Logons (4624)</title>
      <chart>
        <search>
          <query>index=windows EventCode=4624 | timechart span=10m count as success_logons</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
        </search>
        <option name="charting.chart">line</option>
      </chart>
    </panel>
  </row>
  <row>
    <panel>
      <title>Failed Logons by Account</title>
      <table>
        <search>
          <query>index=windows EventCode=4625 | stats count by Account_Name, Source_Network_Address | sort -count</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
        </search>
      </table>
    </panel>
    <panel>
      <title>Linux SSH Failures</title>
      <table>
        <search>
          <query>index=linux ("Failed password" OR "Invalid user") | rex field=_raw "from (?&lt;src_ip&gt;\d+\.\d+\.\d+\.\d+)" | stats count by src_ip | sort -count</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
        </search>
      </table>
    </panel>
  </row>
</form>
